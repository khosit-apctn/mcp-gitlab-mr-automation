# GitLab Configuration
# Copy this file to .env and fill in your actual values

# GitLab Personal Access Token (Required)
# Create one at: https://gitlab.com/-/profile/personal_access_tokens
# Required scopes: api, read_api, read_repository, write_repository
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# GitLab Instance URL (Optional)
# If not specified, the server will attempt to parse it from your git remote origin
# Examples:
#   - GitLab.com: https://gitlab.com
#   - Self-hosted: https://gitlab.yourcompany.com
GITLAB_URL=https://gitlab.com
